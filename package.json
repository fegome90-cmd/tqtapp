{
  "name": "tqtapp",
  "private": true,
  "version": "0.1.0",
  "description": "App de comunicación para pacientes con laringectomía total programada — FALP",
  "keywords": [
    "laringectomia",
    "tts",
    "communication-aid",
    "speech"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "biome lint . && tsc --noEmit",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:frontend:install": "npx agent-browser install",
    "test:frontend:install-deps": "npx agent-browser install --with-deps",
    "test:frontend": "bash ./scripts/test-frontend-agent-browser.sh",
    "test:frontend:headed": "AGENT_BROWSER_HEADED=1 bash ./scripts/test-frontend-agent-browser.sh"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.4",
    "agent-browser": "^0.25.4",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4"
  }
}
